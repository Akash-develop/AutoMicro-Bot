# ── LLM Configuration ─────────────────────────────────────
# Provider to use: 'ollama' (local) or 'openai-compat' (cloud)
LLM_PROVIDER=ollama

# Base URL of your LLM server
# Local Ollama: http://localhost:11434
# Cloud Example (Groq): https://api.groq.com/openai/v1
OLLAMA_BASE_URL=http://localhost:11434

# API Key for cloud providers (optional for local Ollama)
OLLAMA_API_KEY=your_api_key_here

# Model to use
# Local: llama3, mistral, etc.
# Cloud: llama-3.1-70b-versatile, etc.
OLLAMA_MODEL=llama3

# ── Database ──────────────────────────────────────────────
# Path to the SQLite database file
DB_PATH=./automicro.db

# ── Server ────────────────────────────────────────────────
# CORS origins allowed (Tauri dev uses localhost:5173)
CORS_ORIGINS=http://localhost:5173,tauri://localhost

# Maximum chat history messages to include in context
MAX_HISTORY_MESSAGES=20
